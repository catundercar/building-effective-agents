{
  "name": "phase-0-llm-core",
  "version": "0.1.0",
  "description": "Phase 0 Lab: Build the Augmented LLM Core — the heart of your Agent",
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.ts",
